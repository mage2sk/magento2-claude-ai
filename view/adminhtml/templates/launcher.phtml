<script>
(function () {
    'use strict';
    const SEND_URL   = <?= json_encode($block->getSendUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const UPLOAD_URL = <?= json_encode($block->getUploadUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const FORM_KEY   = <?= json_encode($block->getFormKey(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;

    const launcherBtn = document.getElementById('claudeai-launcher-btn');
    const widget      = document.getElementById('claudeai-widget');
    const feed        = document.getElementById('cw-feed');
    const input       = document.getElementById('cw-input');
    const sendBtn     = document.getElementById('cw-send');
    const form        = document.getElementById('cw-form');
    const fileIn      = document.getElementById('cw-file');
    const attBox      = document.getElementById('cw-attachments');

    if (!launcherBtn || !widget) return;

    let conversation = [];
    let conversationId = '';
    let pendingAttachments = [];

    function toggle(open) {
        const willOpen = open !== undefined ? open : !widget.classList.contains('is-open');
        widget.classList.toggle('is-open', willOpen);
        launcherBtn.classList.toggle('is-open', willOpen);
        launcherBtn.setAttribute('aria-expanded', String(willOpen));
        if (willOpen) setTimeout(() => input?.focus(), 50);
    }

    launcherBtn.addEventListener('click', () => toggle());
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && widget.classList.contains('is-open')) toggle(false);
    });

    function esc(s) {
        return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function clearEmpty() { const e = feed.querySelector('.claudeai-widget-empty'); if (e) e.remove(); }
    function bubble(role, html) {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'cw-bubble cw-bubble--' + role;
        wrap.innerHTML = html;
        feed.appendChild(wrap);
        feed.scrollTop = feed.scrollHeight;
        return wrap;
    }
    function toolChip(name, summary, status) {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'cw-tool' + (status === 'error' ? ' cw-tool--err' : '');
        wrap.innerHTML = '<code>' + esc(name) + '</code> ' + esc(summary || '');
        feed.appendChild(wrap);
        feed.scrollTop = feed.scrollHeight;
    }
    function thinking() {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'cw-bubble cw-bubble--ai';
        wrap.innerHTML = '<span class="cw-dots"><span></span><span></span><span></span></span>';
        feed.appendChild(wrap);
        feed.scrollTop = feed.scrollHeight;
        return wrap;
    }
    function md(text) {
        let s = esc(text);
        s = s.replace(/```([\s\S]*?)```/g, (_, c) => '<pre>' + c + '</pre>');
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
        s = s.replace(/\n/g, '<br>');
        return s;
    }
    function renderAttachments() {
        if (!pendingAttachments.length) {
            attBox.style.display = 'none'; attBox.innerHTML = ''; return;
        }
        attBox.style.display = 'flex';
        attBox.innerHTML = pendingAttachments.map((a, i) => {
            const thumb = a.preview_url
                ? '<img src="' + esc(a.preview_url) + '" alt="">'
                : '<span>' + (a.is_pdf ? '📄' : a.is_text ? '📝' : '📎') + '</span>';
            return '<div class="cw-att">' + thumb +
                '<span class="name">' + esc(a.name) + '</span>' +
                '<button type="button" class="rm" data-rm="' + i + '">×</button>' +
                '</div>';
        }).join('');
        attBox.querySelectorAll('[data-rm]').forEach(btn => {
            btn.addEventListener('click', () => {
                pendingAttachments.splice(parseInt(btn.dataset.rm, 10), 1);
                renderAttachments();
            });
        });
    }
    async function uploadFile(file) {
        if (file.size > 20 * 1024 * 1024) { bubble('err', 'File too large. Max 20 MB.'); return; }
        const fd = new FormData();
        fd.append('file', file); fd.append('form_key', FORM_KEY);
        fd.append('conversation_id', conversationId);
        try {
            const resp = await fetch(UPLOAD_URL, { method: 'POST', credentials: 'include', body: fd });
            const data = await resp.json();
            if (!data.success) { bubble('err', esc(data.error || 'Upload failed.')); return; }
            const att = {
                name: data.name, mime: data.mime, size: data.size, url: data.url,
                is_image: data.is_image, is_pdf: data.is_pdf, is_text: data.is_text,
                claude_can_see: data.claude_can_see, claude_block: data.claude_block,
            };
            if (data.is_image && data.claude_block && data.claude_block.source) {
                att.preview_url = 'data:' + data.claude_block.source.media_type + ';base64,' + data.claude_block.source.data;
            }
            pendingAttachments.push(att);
            renderAttachments();
        } catch (e) {
            bubble('err', 'Could not upload that file.');
        }
    }
    async function send(message) {
        const attHtml = pendingAttachments.map(a => a.preview_url
            ? '<img class="attached" src="' + esc(a.preview_url) + '" alt="">'
            : '<div style="margin-top:4px;font-size:11px;opacity:.8">📎 ' + esc(a.name) + '</div>'
        ).join('');
        bubble('user', esc(message) + attHtml);
        const sentAttachments = pendingAttachments.slice();
        pendingAttachments = [];
        renderAttachments();
        input.value = ''; input.style.height = 'auto';
        sendBtn.disabled = true;
        const t = thinking();
        try {
            const apiAttachments = sentAttachments.map(a => ({ claude_block: a.claude_block, name: a.name }));
            const resp = await fetch(SEND_URL, {
                method: 'POST', credentials: 'include',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({
                    message, attachments: apiAttachments, history: conversation,
                    conversation_id: conversationId, form_key: FORM_KEY,
                }),
            });
            const data = await resp.json();
            t.remove();
            if (!data.success) { bubble('err', '<strong>Error:</strong> ' + esc(data.error || 'Unknown error')); return; }
            conversationId = data.conversation_id || conversationId;
            conversation = data.conversation || conversation;
            (data.tool_calls || []).forEach(c => {
                const summary = (c.output && (c.output.summary || c.output.message)) || '';
                const status  = (c.output && c.output.status) || 'success';
                toolChip(c.name, summary, status);
            });
            const aiBubble = bubble('ai', md(data.text || '(no reply)'));
            const u = data.usage || {};
            const cost = data.cost_display || '';
            const meta = (data.iterations ? 'iter ' + data.iterations : '') +
                (u.input ? ' · in ' + u.input : '') +
                (u.output ? ' · out ' + u.output : '') +
                (cost ? ' · ' + cost : '');
            if (meta && aiBubble) {
                aiBubble.insertAdjacentHTML('beforeend', '<div class="meta">' + esc(meta) + '</div>');
            }
        } catch (e) {
            t.remove();
            bubble('err', '<strong>Network error:</strong> ' + esc(e.message));
        } finally {
            sendBtn.disabled = false;
            input.focus();
        }
    }
    input?.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 120) + 'px';
    });
    function shouldSend() { return input.value.trim() !== '' || pendingAttachments.length > 0; }
    input?.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            if (shouldSend()) send(input.value.trim());
        }
    });
    form?.addEventListener('submit', e => {
        e.preventDefault();
        if (shouldSend()) send(input.value.trim());
    });
    fileIn?.addEventListener('change', e => {
        const f = e.target.files && e.target.files[0];
        if (f) uploadFile(f);
        e.target.value = '';
    });
})();
</script>
