                </svg>
            </button>
        </div>
    </form>
</div>

<script>
(function () {
    'use strict';
    const STREAM_URL = <?= json_encode($block->getStreamUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const UPLOAD_URL = <?= json_encode($block->getUploadUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const FORM_KEY   = <?= json_encode($block->getFormKey(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;

    const launcherBtn = document.getElementById('pclaude-launcher');
    const widget      = document.getElementById('pclaude-widget');
    const closeBtn    = document.getElementById('pclaude-close');
    const newchatBtn  = document.getElementById('pclaude-newchat');
    const resizeGrip  = document.getElementById('pclaude-resize');
    const feed        = document.getElementById('pclaude-feed');
    const input       = document.getElementById('pclaude-input');
    const sendBtn     = document.getElementById('pclaude-send');
    const stopBtn     = document.getElementById('pclaude-stop');
    const form        = document.getElementById('pclaude-form');
    const composer    = form;
    const fileIn      = document.getElementById('pclaude-file');
    const attBox      = document.getElementById('pclaude-attachments');

    if (!launcherBtn || !widget) return;

    let conversation = [];
    let conversationId = '';
    let pendingAttachments = [];
    let activeAbort = null;

    function toggle(open) {
        const willOpen = open !== undefined ? open : !widget.classList.contains('is-open');
        widget.classList.toggle('is-open', willOpen);
        launcherBtn.classList.toggle('is-open', willOpen);
        launcherBtn.setAttribute('aria-expanded', String(willOpen));
        if (willOpen) setTimeout(() => input?.focus(), 60);
    }
    launcherBtn.addEventListener('click', () => toggle());
    closeBtn?.addEventListener('click', () => toggle(false));
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && widget.classList.contains('is-open')) toggle(false);
    });

    function esc(s) {
        return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function nearBottom() { return (feed.scrollHeight - feed.scrollTop - feed.clientHeight) < 60; }
    let _stick = true;
    feed.addEventListener('scroll', () => { _stick = nearBottom(); });
    function scrollDown(force) {
        if (force || _stick) feed.scrollTop = feed.scrollHeight;
    }
    function clearEmpty() { const e = feed.querySelector('.pclaude-empty'); if (e) e.remove(); }

    function bubble(role, html) {
        clearEmpty();
        const row = document.createElement('div');
        row.className = 'pclaude-row ' + role;
        let inner = '';
        if (role === 'ai') {
            inner += '<div class="pclaude-avatar">C</div>';
        }
        inner += '<div class="pclaude-bubble">' + html + '</div>';
        row.innerHTML = inner;
        feed.appendChild(row);
        scrollDown();
        return row.querySelector('.pclaude-bubble');
    }
    function thinking() {
        clearEmpty();
        const row = document.createElement('div');
        row.className = 'pclaude-row ai';
        row.innerHTML = '<div class="pclaude-avatar">C</div>' +
            '<div class="pclaude-bubble"><span class="pclaude-typing"><span></span><span></span><span></span></span></div>';
        feed.appendChild(row);
        scrollDown();
        return row.querySelector('.pclaude-bubble');
    }
    function setStatus(el, text) {
        if (!el) return;
        el.innerHTML = '<span class="pclaude-typing"><span></span><span></span><span></span></span> ' +
            '<span style="color:#707070;font-size:12.5px">' + esc(text) + '</span>';
        scrollDown();
    }
    function toolChip(name, summary, status) {
        const div = document.createElement('div');
        div.className = 'pclaude-tool' + (status === 'error' ? ' err' : '');
        div.innerHTML = '<code>' + esc(name) + '</code>' +
            (summary ? '<span>' + esc(summary) + '</span>' : '');
        feed.appendChild(div);
        scrollDown();
    }
    function md(text) {
        let s = esc(text);
        s = s.replace(/```([\s\S]*?)```/g, (_, c) => '<pre>' + c + '</pre>');
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
        s = s.replace(/\n/g, '<br>');
        return s;
    }
    function renderAttachments() {
        if (!pendingAttachments.length) {
            attBox.style.display = 'none'; attBox.innerHTML = ''; return;
        }
        attBox.style.display = 'flex';
        attBox.innerHTML = pendingAttachments.map((a, i) => {
            const thumb = a.preview_url
                ? '<img src="' + esc(a.preview_url) + '" alt="">'
                : '<span>' + (a.is_pdf ? '📄' : a.is_text ? '📝' : '📎') + '</span>';
            return '<div class="pclaude-att">' + thumb +
                '<span class="name">' + esc(a.name) + '</span>' +
                '<button type="button" data-rm="' + i + '">×</button></div>';
        }).join('');
        attBox.querySelectorAll('[data-rm]').forEach(btn => {
            btn.addEventListener('click', () => {
                pendingAttachments.splice(parseInt(btn.dataset.rm, 10), 1);
                renderAttachments();
            });
        });
    }
    async function uploadFile(file) {
        if (file.size > 20 * 1024 * 1024) { bubble('err', 'File too large. Max 20 MB.'); return; }
        const fd = new FormData();
        fd.append('file', file); fd.append('form_key', FORM_KEY);
        fd.append('conversation_id', conversationId);
        try {
            const resp = await fetch(UPLOAD_URL, { method: 'POST', credentials: 'include', body: fd });
            const data = await resp.json();
            if (!data.success) { bubble('err', esc(data.error || 'Upload failed.')); return; }
            const att = {
                name: data.name, mime: data.mime, size: data.size, url: data.url,
                is_image: data.is_image, is_pdf: data.is_pdf, is_text: data.is_text,
                claude_can_see: data.claude_can_see, claude_block: data.claude_block,
                path_note: data.path_note,
            };
            if (data.is_image && data.claude_block && data.claude_block.source) {
                att.preview_url = 'data:' + data.claude_block.source.media_type + ';base64,' + data.claude_block.source.data;
            }
            pendingAttachments.push(att);
            renderAttachments();
        } catch (e) {
            bubble('err', 'Could not upload that file.');
        }
    }
    async function send(message) {
        const attHtml = pendingAttachments.map(a => a.preview_url
            ? '<img class="attached" src="' + esc(a.preview_url) + '" alt="">'
            : '<div style="margin-top:4px;font-size:11.5px;opacity:.85">📎 ' + esc(a.name) + '</div>'
        ).join('');
        bubble('user', esc(message) + attHtml);
        _stick = true; scrollDown(true);
        const sent = pendingAttachments.slice();
        pendingAttachments = [];
        renderAttachments();
        input.value = ''; input.style.height = 'auto';
        composer.classList.add('is-busy');
        stopBtn.classList.add('is-active');

        const apiAttachments = sent.map(a => ({ claude_block: a.claude_block, path_note: a.path_note, name: a.name }));
        const t = thinking();
        setStatus(t, 'Reading your message…');

        const ctrl = new AbortController();
        activeAbort = ctrl;
        let done = null;
        try {
            const resp = await fetch(STREAM_URL, {
                method: 'POST', credentials: 'include', signal: ctrl.signal,
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'text/event-stream' },
                body: JSON.stringify({
                    message, attachments: apiAttachments, history: conversation,
                    conversation_id: conversationId, form_key: FORM_KEY,
                }),
            });
            if (!resp.ok || !resp.body) { t.remove(); bubble('err', '<strong>Error:</strong> HTTP ' + resp.status); return; }
            const reader = resp.body.getReader();
            const decoder = new TextDecoder('utf-8');
            let buffer = '';
            const handle = (event, data) => {
                if (event === 'thinking')        setStatus(t, data.message || 'Thinking…');
                else if (event === 'tool_start') setStatus(t, 'Calling ' + (data.name || ''));
                else if (event === 'tool_done') {
                    const summary = (data.summary || '').slice(0, 110);
                    t.parentElement.insertAdjacentElement('beforebegin', (() => {
                        const d = document.createElement('div');
                        d.className = 'pclaude-tool' + (data.status === 'error' ? ' err' : '');
                        d.innerHTML = '<code>' + esc(data.name) + '</code><span>' + esc(summary) + '</span>';
                        return d;
                    })());
                    setStatus(t, 'Got results — figuring out next step…');
                }
                else if (event === 'writing_reply') setStatus(t, 'Writing the reply…');
                else if (event === 'done')          done = data;
                else if (event === 'error') {
                    t.remove();
                    bubble('err', '<strong>Error:</strong> ' + esc(data.message || 'Unknown'));
                }
            };
            while (true) {
                const { value, done: sd } = await reader.read();
                if (sd) break;
                buffer += decoder.decode(value, { stream: true });
                let idx;
                while ((idx = buffer.indexOf('\n\n')) !== -1) {
                    const chunk = buffer.slice(0, idx); buffer = buffer.slice(idx + 2);
                    let evt = 'message', payload = '';
                    for (const line of chunk.split('\n')) {
                        if (line.startsWith('event:')) evt = line.slice(6).trim();
                        else if (line.startsWith('data:')) payload += line.slice(5).trim();
                    }
                    if (payload) { try { handle(evt, JSON.parse(payload)); } catch {} }
                }
            }
            if (!done) { t.remove(); return; }
            t.remove();
            conversationId = done.conversation_id || conversationId;
            conversation = done.conversation || conversation;
            const aiBubble = bubble('ai', md(done.text || '(no reply)'));
            const u = done.usage || {};
            const cost = done.cost_display || '';
            const meta = (done.iterations ? 'iter ' + done.iterations : '') +
                (u.input ? ' · in ' + u.input : '') +
                (u.output ? ' · out ' + u.output : '') +
                (cost ? ' · ' + cost : '');
            if (meta && aiBubble) {
                aiBubble.insertAdjacentHTML('beforeend', '<div class="meta">' + esc(meta) + '</div>');
            }
        } catch (e) {
            t.remove();
            if (e.name === 'AbortError') {
                bubble('ai', '<em style="color:#b30000">Stopped.</em>');
            } else {
                bubble('err', '<strong>Network error:</strong> ' + esc(e.message));
            }
        } finally {
            activeAbort = null;
            composer.classList.remove('is-busy');
            stopBtn.classList.remove('is-active');
            input.focus();
        }
    }
    stopBtn?.addEventListener('click', () => {
        if (activeAbort) { activeAbort.abort(); }
    });
    newchatBtn?.addEventListener('click', () => {
        if (activeAbort) activeAbort.abort();
        conversation = []; conversationId = '';
        pendingAttachments = []; renderAttachments();
        feed.innerHTML = '<div class="pclaude-empty">' +
            '<div class="pclaude-empty-mark"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg></div>' +
            '<h3>How can I help today?</h3>' +
            '<p>Fresh chat — your previous one is saved under Conversations.</p></div>';
        input.focus();
    });

    input?.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 140) + 'px';
    });
    function shouldSend() { return input.value.trim() !== '' || pendingAttachments.length > 0; }
    input?.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            if (shouldSend()) send(input.value.trim());
        }
    });
    form?.addEventListener('submit', e => {
        e.preventDefault();
        if (shouldSend()) send(input.value.trim());
    });
    fileIn?.addEventListener('change', e => {
        const f = e.target.files && e.target.files[0];
        if (f) uploadFile(f);
        e.target.value = '';
    });
    document.querySelectorAll('.pclaude-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            const p = chip.dataset.prompt || '';
            input.value = p; input.dispatchEvent(new Event('input'));
            send(p);
        });
    });

    // ---------- Resize ----------
    const SIZE_KEY = 'pclaude_size_v2';
    function applySaved() {
        try {
            const raw = localStorage.getItem(SIZE_KEY);
            if (!raw) return;
            const s = JSON.parse(raw);
            if (s && Number.isFinite(s.w) && Number.isFinite(s.h)) {
                widget.style.width  = Math.max(320, s.w) + 'px';
                widget.style.height = Math.max(380, s.h) + 'px';
            }
        } catch {}
    }
    function saveSize(w, h) { try { localStorage.setItem(SIZE_KEY, JSON.stringify({ w, h })); } catch {} }
    applySaved();

    let rs = null;
    resizeGrip?.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        const r = widget.getBoundingClientRect();
        widget.style.bottom = (window.innerHeight - r.bottom) + 'px';
        widget.style.right  = (window.innerWidth  - r.right)  + 'px';
        rs = { startX: e.clientX, startY: e.clientY, ar: r.right, ab: r.bottom };
        document.body.classList.add('pclaude-resizing');
        resizeGrip.setPointerCapture(e.pointerId);
    });
    resizeGrip?.addEventListener('pointermove', (e) => {
        if (!rs) return;
        const w = Math.max(320, Math.min(window.innerWidth  - 24, rs.ar - e.clientX));
        const h = Math.max(380, Math.min(window.innerHeight - 24, rs.ab - e.clientY));
        widget.style.width  = w + 'px';
        widget.style.height = h + 'px';
    });
    function endResize(e) {
        if (!rs) return;
        const r = widget.getBoundingClientRect();
        saveSize(r.width, r.height); rs = null;
        document.body.classList.remove('pclaude-resizing');
        try { resizeGrip.releasePointerCapture(e.pointerId); } catch {}
    }
    resizeGrip?.addEventListener('pointerup',     endResize);
    resizeGrip?.addEventListener('pointercancel', endResize);
})();
</script>
