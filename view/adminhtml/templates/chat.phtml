    <?php if ($block->isDryRun()): ?>
        <div class="message message-notice">
            <span><strong><?= $escaper->escapeHtml(__('Dry run mode is ON.')) ?></strong>
                <?= $escaper->escapeHtml(__('The AI will tell you what it WOULD change but won\'t touch any data.')) ?>
            </span>
        </div>
    <?php endif; ?>

    <div class="claudeai-chat">
        <aside class="claudeai-chat-side">
            <div class="claudeai-side-head">
                <h4 style="margin:0"><?= $escaper->escapeHtml(__('Conversations')) ?></h4>
                <button type="button" id="claudeai-new-chat" class="claudeai-newchat-btn" title="<?= $escaper->escapeHtmlAttr(__('Start a new conversation')) ?>">
                    + <?= $escaper->escapeHtml(__('New')) ?>
                </button>
            </div>
            <ul class="claudeai-chat-history" id="claudeai-history">
                <?php if (empty($recent)): ?>
                    <li class="claudeai-history-empty"><?= $escaper->escapeHtml(__('No previous conversations yet — your first chat will appear here.')) ?></li>
                <?php else: ?>
                    <?php foreach ($recent as $c): ?>
                        <li class="claudeai-history-item"
                            data-cid="<?= $escaper->escapeHtmlAttr($c['conversation_id']) ?>"
                            title="<?= $escaper->escapeHtmlAttr($c['conversation_id']) ?>">
                            <div class="claudeai-history-line"><?= $escaper->escapeHtml($c['preview'] !== '' ? $c['preview'] : '(file or empty)') ?></div>
                            <div class="claudeai-history-meta">
                                <?= $escaper->escapeHtml(date('M j H:i', strtotime($c['last_at']))) ?>
                                · <?= (int) $c['turns'] ?> <?= $escaper->escapeHtml(__('turns')) ?>
                            </div>
                        </li>
                    <?php endforeach; ?>
                <?php endif; ?>
            </ul>

            <h4 style="margin-top:14px"><?= $escaper->escapeHtml(__('Capabilities')) ?></h4>
            <ul class="claudeai-chat-tools">
                <?php foreach ($tools as $tool): ?>
                    <li>
                        <code><?= $escaper->escapeHtml($tool['name']) ?></code>
                        <small><?= $escaper->escapeHtml(mb_strimwidth($tool['description'], 0, 120, '…')) ?></small>
                    </li>
                <?php endforeach; ?>
            </ul>

            <h4><?= $escaper->escapeHtml(__('Try asking')) ?></h4>
            <ul class="claudeai-chat-suggest">
                <?php foreach ($block->getSuggestions() as $s): ?>
                    <li class="claudeai-chat-chip" data-suggestion="<?= $escaper->escapeHtmlAttr($s) ?>"><?= $escaper->escapeHtml($s) ?></li>
                <?php endforeach; ?>
            </ul>

            <h4 style="margin-top:14px"><?= $escaper->escapeHtml(__('Model')) ?></h4>
            <div style="font-size:12px;color:#777"><?= $escaper->escapeHtml($block->getModel()) ?></div>
        </aside>

        <main class="claudeai-chat-main">
            <div class="claudeai-chat-feed" id="claudeai-feed">
                <div class="claudeai-chat-empty">
                    <h3><?= $escaper->escapeHtml(__('Hi! I\'m Claude.')) ?></h3>
                    <p><?= $escaper->escapeHtml(__('Ask me anything about your store. I can search products, customers, orders, and update prices in bulk — every change is undoable.')) ?></p>
                </div>
            </div>
            <div class="claudeai-attachments" id="claudeai-attachments" style="display:none"></div>
            <form class="claudeai-composer" id="claudeai-form">
                <label class="claudeai-attach-btn" title="<?= $escaper->escapeHtmlAttr(__('Attach a file (image, PDF, doc, csv, zip…)')) ?>">
                    <input type="file" id="claudeai-file"
                           accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.csv,.txt,.json,.xml,.md,.log,.zip,.tar,.gz"
                           hidden <?= !$block->isConfigured() ? 'disabled' : '' ?>>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </label>
                <textarea id="claudeai-input"
                          class="claudeai-composer-input"
                          rows="1"
                          placeholder="<?= $escaper->escapeHtmlAttr(__('Ask anything about your store…')) ?>"
                          <?= !$block->isConfigured() ? 'disabled' : '' ?>></textarea>
                <button type="submit"
                        class="action-primary"
                        id="claudeai-send"
                        <?= !$block->isConfigured() ? 'disabled' : '' ?>><span><?= $escaper->escapeHtml(__('Send')) ?></span></button>
            </form>
        </main>
    </div>

    <div class="claudeai-credit">
        <?= $escaper->escapeHtml(__('Designed & developed with')) ?> <span class="heart">♥</span>
        <?= $escaper->escapeHtml(__('by')) ?> <a href="https://kishansavaliya.com" target="_blank" rel="noopener">Kishan Savaliya</a> · Panth Infotech
    </div>
</div>

<script>
(function () {
    'use strict';
    const SEND_URL   = <?= json_encode($block->getSendUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const UPLOAD_URL = <?= json_encode($block->getUploadUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const LOAD_URL   = <?= json_encode($block->getLoadUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const FORM_KEY   = <?= json_encode($block->getFormKey(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;

    const feed     = document.getElementById('claudeai-feed');
    const input    = document.getElementById('claudeai-input');
    const sendBtn  = document.getElementById('claudeai-send');
    const form     = document.getElementById('claudeai-form');
    const fileIn   = document.getElementById('claudeai-file');
    const attBox   = document.getElementById('claudeai-attachments');

    let conversation = [];
    let conversationId = '';
    /** Pending attachments (each carries { name, mime, size, url, claude_block, preview_url? }) */
    let pendingAttachments = [];

    // Pre-fill from ?prompt= so the dashboard quick-actions can deep-link
    const url = new URL(window.location.href);
    const initial = url.searchParams.get('prompt');
    if (initial && input && !input.disabled) {
        input.value = initial;
        input.focus();
    }

    function esc(s) {
        return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function clearEmpty() { const e = feed.querySelector('.claudeai-chat-empty'); if (e) e.remove(); }
    function bubble(role, html) {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'claudeai-bubble claudeai-bubble--' + role;
        wrap.innerHTML = '<div class="claudeai-bubble-body">' + html + '</div>';
        feed.appendChild(wrap);
        feed.scrollTop = feed.scrollHeight;
        return wrap;
    }
    function toolChip(name, summary, status) {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'claudeai-tool-call' + (status === 'error' ? ' claudeai-tool-call--err' : '');
        wrap.innerHTML = '<code>' + esc(name) + '</code><span>' + esc(summary) + '</span>';
        feed.appendChild(wrap);
        feed.scrollTop = feed.scrollHeight;
    }
    function thinking() {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'claudeai-bubble claudeai-bubble--ai';
        wrap.innerHTML = '<div class="claudeai-bubble-body"><span class="claudeai-dots"><span></span><span></span><span></span></span></div>';
        feed.appendChild(wrap);
        feed.scrollTop = feed.scrollHeight;
        return wrap;
    }
    function md(text) {
        let s = esc(text);
        s = s.replace(/```([\s\S]*?)```/g, (_, c) => '<pre style="background:#f5f5f5;padding:8px;border-radius:3px;font-size:12px;overflow-x:auto;">' + c + '</pre>');
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
        s = s.replace(/\n/g, '<br>');
        return s;
    }

    function renderAttachments() {
        if (!pendingAttachments.length) {
            attBox.style.display = 'none';
            attBox.innerHTML = '';
            return;
        }
        attBox.style.display = 'flex';
        attBox.innerHTML = pendingAttachments.map((a, i) => {
            const thumb = a.preview_url
                ? '<img src="' + esc(a.preview_url) + '" alt="">'
                : '<span class="claudeai-att-icon">' + (a.is_pdf ? '📄' : a.is_text ? '📝' : '📎') + '</span>';
            const note = a.claude_can_see ? '' : ' (Claude can\'t read inside)';
            return '<div class="claudeai-att-chip">' +
                thumb +
                '<span class="claudeai-att-name">' + esc(a.name) + esc(note) + '</span>' +
                '<button type="button" data-claudeai-rm="' + i + '" class="claudeai-att-rm">×</button>' +
                '</div>';
        }).join('');
        attBox.querySelectorAll('[data-claudeai-rm]').forEach(btn => {
            btn.addEventListener('click', () => {
                const i = parseInt(btn.dataset.claudeaiRm, 10);
                pendingAttachments.splice(i, 1);
                renderAttachments();
            });
        });
    }

    async function uploadFile(file) {
        if (file.size > 20 * 1024 * 1024) {
            bubble('err', 'File too large. Maximum 20 MB.');
            return;
        }
        const fd = new FormData();
        fd.append('file', file);
        fd.append('form_key', FORM_KEY);
        fd.append('conversation_id', conversationId);
        try {
            const resp = await fetch(UPLOAD_URL, { method: 'POST', credentials: 'include', body: fd });
            const data = await resp.json();
            if (!data.success) {
                bubble('err', esc(data.error || 'Upload failed.'));
                return;
            }
            const att = {
                name: data.name,
                mime: data.mime,
                size: data.size,
                url: data.url,
                is_image: data.is_image,
                is_pdf: data.is_pdf,
                is_text: data.is_text,
                claude_can_see: data.claude_can_see,
                claude_block: data.claude_block,
            };
            if (data.is_image && data.claude_block && data.claude_block.source) {
                att.preview_url = 'data:' + data.claude_block.source.media_type + ';base64,' + data.claude_block.source.data;
            }
            pendingAttachments.push(att);
            renderAttachments();
        } catch (e) {
            bubble('err', 'Could not upload that file.');
        }
    }

    async function send(message) {
        // Render the user bubble — include thumbnails of attached images.
        const attHtml = pendingAttachments.map(a => {
            if (a.preview_url) return '<img class="claudeai-bubble-attached" src="' + esc(a.preview_url) + '" alt="attachment">';
            return '<div class="claudeai-bubble-att-chip">📎 ' + esc(a.name) + '</div>';
        }).join('');
        bubble('user', esc(message) + attHtml);
        const sentAttachments = pendingAttachments.slice();
        pendingAttachments = [];
        renderAttachments();
        input.value = ''; input.style.height = 'auto';
        sendBtn.disabled = true;
        const t = thinking();
        try {
            // Strip preview-only fields before sending — server only needs claude_block.
            const apiAttachments = sentAttachments.map(a => ({ claude_block: a.claude_block, name: a.name }));
            const resp = await fetch(SEND_URL, {
                method: 'POST', credentials: 'include',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({
                    message,
                    attachments: apiAttachments,
                    history: conversation,
                    conversation_id: conversationId,
                    form_key: FORM_KEY,
                }),
            });
            const data = await resp.json();
            t.remove();
            if (!data.success) {
                bubble('err', '<strong><?= $escaper->escapeJs(__('Error:')) ?></strong> ' + esc(data.error || 'Unknown error'));
                return;
            }
            conversationId = data.conversation_id || conversationId;
            conversation = data.conversation || conversation;

            (data.tool_calls || []).forEach(c => {
                const summary = (c.output && (c.output.summary || c.output.message)) || '';
                const status  = (c.output && c.output.status) || 'success';
                toolChip(c.name, summary, status);
            });
            bubble('ai', md(data.text || '(no reply)'));

            const u = data.usage || {};
            const cost = data.cost_display || '';
            const meta = '<?= $escaper->escapeJs(__('Iter:')) ?> ' + (data.iterations || 1) +
                ' · in ' + (u.input || 0) + ' · out ' + (u.output || 0) +
                (u.cache_read ? ' · cache: ' + u.cache_read : '') +
                (cost ? ' · ' + cost : '');
            const last = feed.querySelector('.claudeai-bubble--ai:last-child .claudeai-bubble-body');
            if (last) last.insertAdjacentHTML('beforeend', '<div class="claudeai-meta">' + meta + '</div>');
        } catch (e) {
            t.remove();
            bubble('err', '<strong><?= $escaper->escapeJs(__('Network error:')) ?></strong> ' + esc(e.message));
        } finally {
            sendBtn.disabled = false;
            input.focus();
        }
    }

    input?.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 200) + 'px';
    });
    function shouldSend() {
        return input.value.trim() !== '' || pendingAttachments.length > 0;
    }
    input?.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            if (shouldSend()) send(input.value.trim());
        }
    });
    form?.addEventListener('submit', e => {
        e.preventDefault();
        if (shouldSend()) send(input.value.trim());
    });
    fileIn?.addEventListener('change', e => {
        const f = e.target.files && e.target.files[0];
        if (f) uploadFile(f);
        e.target.value = '';
    });
    document.querySelectorAll('.claudeai-chat-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            input.value = chip.dataset.suggestion || '';
            input.focus();
            input.dispatchEvent(new Event('input'));
        });
    });

    // Reset to a brand-new conversation (clears feed + history + cid).
    function newChat() {
        conversation = [];
        conversationId = '';
        pendingAttachments = [];
        renderAttachments();
        feed.innerHTML = '<div class="claudeai-chat-empty">' +
            '<h3><?= $escaper->escapeJs(__('Hi! I\'m Claude.')) ?></h3>' +
            '<p><?= $escaper->escapeJs(__('Ask me anything about your store.')) ?></p>' +
            '</div>';
        document.querySelectorAll('.claudeai-history-item').forEach(li => li.classList.remove('is-active'));
        input.focus();
    }
    document.getElementById('claudeai-new-chat')?.addEventListener('click', newChat);

    // Replay one stored conversation into the feed in lightweight bubble form.
    function replay(messages) {
        feed.innerHTML = '';
        for (const msg of messages || []) {
            const blocks = Array.isArray(msg.content) ? msg.content
                         : [{ type: 'text', text: String(msg.content || '') }];
            const role = msg.role === 'assistant' ? 'ai' : 'user';
            for (const b of blocks) {
                if (b.type === 'text') {
                    bubble(role, md(b.text || ''));
                } else if (b.type === 'image' && b.source?.data) {
                    const uri = 'data:' + (b.source.media_type || 'image/png') + ';base64,' + b.source.data;
                    bubble(role, '<img class="claudeai-bubble-attached" src="' + esc(uri) + '" alt="">');
                } else if (b.type === 'document') {
                    bubble(role, '<div class="claudeai-bubble-att-chip">📄 attached document</div>');
                } else if (b.type === 'tool_use') {
                    toolChip(b.name || 'tool', '(replayed call)', 'success');
                } else if (b.type === 'tool_result') {
                    const txt = typeof b.content === 'string' ? b.content
                              : Array.isArray(b.content) ? b.content.map(x => x.text || '').join(' ')
                              : '';
                    if (txt) toolChip('result', mb(txt, 80), 'success');
                }
            }
        }
    }
    function mb(s, n) { s = String(s || ''); return s.length > n ? s.slice(0, n) + '…' : s; }

    async function loadConversation(cid) {
        if (!cid) return;
        try {
            const url = LOAD_URL + (LOAD_URL.includes('?') ? '&' : '?') + 'cid=' + encodeURIComponent(cid);
            const resp = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const data = await resp.json();
            if (!data.success) {
                bubble('err', '<strong><?= $escaper->escapeJs(__('Could not load:')) ?></strong> ' + esc(data.error || 'unknown'));
                return;
            }
            conversation = data.messages || [];
            conversationId = data.conversation_id || cid;
            replay(conversation);
            document.querySelectorAll('.claudeai-history-item').forEach(li => {
                li.classList.toggle('is-active', li.dataset.cid === cid);
            });
        } catch (e) {
            bubble('err', '<strong><?= $escaper->escapeJs(__('Network error:')) ?></strong> ' + esc(e.message));
        }
    }

    document.querySelectorAll('.claudeai-history-item').forEach(li => {
        li.addEventListener('click', () => loadConversation(li.dataset.cid || ''));
    });
})();
</script>
