<script>
(function () {
    'use strict';
    const SEND_URL   = <?= json_encode($block->getSendUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const STREAM_URL = <?= json_encode($block->getStreamUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const UPLOAD_URL = <?= json_encode($block->getUploadUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const LOAD_URL   = <?= json_encode($block->getLoadUrl(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;
    const FORM_KEY   = <?= json_encode($block->getFormKey(), JSON_HEX_TAG | JSON_HEX_AMP) ?>;

    // Sparkle glyph used for the AI avatar — same mark as the launcher widget
    // and the empty-state icon, so the brand stays consistent everywhere.
    const AI_GLYPH =
        '<svg viewBox="0 0 24 24" aria-hidden="true">' +
        '<path d="M12 2.5l1.95 5.55L19.5 10l-5.55 1.95L12 17.5l-1.95-5.55L4.5 10l5.55-1.95L12 2.5z"/>' +
        '<path d="M18.5 14.5l.85 2.4 2.4.85-2.4.85-.85 2.4-.85-2.4-2.4-.85 2.4-.85.85-2.4z" opacity=".75"/>' +
        '</svg>';

    // Plain-English labels for tool names — shown in the "thinking" status
    // line so the user sees "Looking up products" instead of "get_products".
    const FRIENDLY_TOOL = {
        get_products:           'Looking up products',
        manage_products:        'Updating products',
        update_product_price:   'Changing prices',
        update_product_status:  'Turning products on/off',
        update_inventory:       'Updating stock',
        manage_categories:      'Managing categories',
        customers:              'Looking up customers',
        orders:                 'Working with orders',
        manage_cms_pages:       'Editing pages',
        manage_cms_blocks:      'Editing blocks',
        store_insights:         'Counting things',
        get_low_stock_products: 'Finding low stock',
        store_info:             'Reading store info',
        update_config:          'Updating settings',
        set_store_logo:         'Setting the logo',
        get_modules:            'Listing modules',
        database_query:         'Reading the database',
        cache_reindex:          'Refreshing the cache',
        restore_checkpoint:     'Undoing the change',
    };
    function friendlyTool(name) { return FRIENDLY_TOOL[name] || name.replace(/_/g, ' '); }

    const feed     = document.getElementById('claudeai-feed');
    const input    = document.getElementById('claudeai-input');
    const sendBtn  = document.getElementById('claudeai-send');
    const stopBtn  = document.getElementById('claudeai-stop');
    const form     = document.getElementById('claudeai-form');
    const fileIn   = document.getElementById('claudeai-file');
    const attBox   = document.getElementById('claudeai-attachments');

    let conversation = [];
    let conversationId = '';
    /** Pending attachments (each carries { name, mime, size, url, claude_block, preview_url? }) */
    let pendingAttachments = [];

    // Pre-fill from ?prompt= so the dashboard quick-actions can deep-link
    const url = new URL(window.location.href);
    const initial = url.searchParams.get('prompt');
    if (initial && input && !input.disabled) {
        input.value = initial;
        input.focus();
    }

    function esc(s) {
        return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    // Smart auto-scroll — only follow the latest content if the user is
    // already near the bottom. Don't yank them down if they scrolled up
    // to read older messages mid-conversation.
    function nearBottom() {
        return (feed.scrollHeight - feed.scrollTop - feed.clientHeight) < 80;
    }
    let _stickToBottom = true;
    feed.addEventListener('scroll', () => { _stickToBottom = nearBottom(); });
    function autoScroll(force) {
        if (force || _stickToBottom) {
            feed.scrollTop = feed.scrollHeight;
        }
    }
    function clearEmpty() { const e = feed.querySelector('.claudeai-chat-empty'); if (e) e.remove(); }

    // Walk back through preceding bubbles — if the most recent one is also
    // an AI bubble, this new one is a continuation of the same turn and
    // should hide its avatar (so multi-block replies don't stack glyphs).
    function isContinuation() {
        for (let n = feed.lastElementChild; n; n = n.previousElementSibling) {
            if (n.classList.contains('claudeai-tool-call')) continue;
            if (n.classList.contains('claudeai-bubble')) {
                return n.classList.contains('claudeai-bubble--ai');
            }
        }
        return false;
    }
    function bubble(role, html) {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'claudeai-bubble claudeai-bubble--' + role;
        if (role === 'ai' && isContinuation()) wrap.classList.add('is-continuation');
        let inner = '';
        if (role === 'ai') {
            inner += '<div class="claudeai-avatar">' + AI_GLYPH + '</div>';
        }
        inner += '<div class="claudeai-bubble-body">' + html + '</div>';
        wrap.innerHTML = inner;
        feed.appendChild(wrap);
        autoScroll();
        return wrap;
    }
    function thinking() {
        clearEmpty();
        const wrap = document.createElement('div');
        wrap.className = 'claudeai-bubble claudeai-bubble--ai';
        if (isContinuation()) wrap.classList.add('is-continuation');
        wrap.innerHTML = '<div class="claudeai-avatar">' + AI_GLYPH + '</div>' +
            '<div class="claudeai-bubble-body"><span class="claudeai-dots"><span></span><span></span><span></span></span></div>';
        feed.appendChild(wrap);
        autoScroll();
        return wrap;
    }
    function md(text) {
        let s = esc(text);
        s = s.replace(/```([\s\S]*?)```/g, (_, c) => '<pre>' + c + '</pre>');
        s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
        s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
        s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
        s = s.replace(/\n/g, '<br>');
        return s;
    }

    function renderAttachments() {
        if (!pendingAttachments.length) {
            attBox.style.display = 'none';
            attBox.innerHTML = '';
            return;
        }
        attBox.style.display = 'flex';
        attBox.innerHTML = pendingAttachments.map((a, i) => {
            const thumb = a.preview_url
                ? '<img src="' + esc(a.preview_url) + '" alt="">'
                : '<span class="claudeai-att-icon">' + (a.is_pdf ? '📄' : a.is_text ? '📝' : '📎') + '</span>';
            const note = a.claude_can_see ? '' : ' (I can\'t read inside)';
            return '<div class="claudeai-att-chip">' +
                thumb +
                '<span class="claudeai-att-name">' + esc(a.name) + esc(note) + '</span>' +
                '<button type="button" data-claudeai-rm="' + i + '" class="claudeai-att-rm">×</button>' +
                '</div>';
        }).join('');
        attBox.querySelectorAll('[data-claudeai-rm]').forEach(btn => {
            btn.addEventListener('click', () => {
                const i = parseInt(btn.dataset.claudeaiRm, 10);
                pendingAttachments.splice(i, 1);
                renderAttachments();
            });
        });
    }

    async function uploadFile(file) {
        if (file.size > 20 * 1024 * 1024) {
            bubble('err', 'That file is too big. Please use one under 20 MB.');
            return;
        }
        const fd = new FormData();
        fd.append('file', file);
        fd.append('form_key', FORM_KEY);
        fd.append('conversation_id', conversationId);
        try {
            const resp = await fetch(UPLOAD_URL, { method: 'POST', credentials: 'include', body: fd });
            const data = await resp.json();
            if (!data.success) {
                bubble('err', esc(data.error || 'Upload failed.'));
                return;
            }
            const att = {
                name: data.name,
                mime: data.mime,
                size: data.size,
                url: data.url,
                is_image: data.is_image,
                is_pdf: data.is_pdf,
                is_text: data.is_text,
                claude_can_see: data.claude_can_see,
                claude_block: data.claude_block,
                path_note: data.path_note,
            };
            if (data.is_image && data.claude_block && data.claude_block.source) {
                att.preview_url = 'data:' + data.claude_block.source.media_type + ';base64,' + data.claude_block.source.data;
            }
            pendingAttachments.push(att);
            renderAttachments();
        } catch (e) {
            bubble('err', 'Could not upload that file.');
        }
    }

    function setStatus(el, text) {
        if (!el) return;
        const body = el.querySelector('.claudeai-bubble-body') || el;
        body.innerHTML = '<span class="claudeai-status-line">' +
            '<span class="claudeai-dots"><span></span><span></span><span></span></span>' +
            ' <em>' + esc(text) + '</em></span>';
        autoScroll();
    }

    let activeAbort = null;
    stopBtn?.addEventListener('click', () => { if (activeAbort) activeAbort.abort(); });

    async function streamSend(message, sentAttachments) {
        const apiAttachments = sentAttachments.map(a => ({
            claude_block: a.claude_block,
            path_note:    a.path_note,
            name:         a.name,
        }));
        const t = thinking();
        setStatus(t, '<?= $escaper->escapeJs(__('Reading what you said…')) ?>');

        const ctrl = new AbortController();
        activeAbort = ctrl;
        sendBtn.style.display = 'none';
        if (stopBtn) stopBtn.classList.add('is-active');

        const resp = await fetch(STREAM_URL, {
            method: 'POST', credentials: 'include', signal: ctrl.signal,
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'text/event-stream' },
            body: JSON.stringify({
                message,
                attachments: apiAttachments,
                history: conversation,
                conversation_id: conversationId,
                form_key: FORM_KEY,
            }),
        });
        if (!resp.ok || !resp.body) {
            t.remove();
            bubble('err', '<strong><?= $escaper->escapeJs(__('Something went wrong:')) ?></strong> HTTP ' + resp.status);
            return;
        }
        const reader = resp.body.getReader();
        const decoder = new TextDecoder('utf-8');
        let buffer = '';
        let done = null;

        const handle = (event, data) => {
            if (event === 'thinking') {
                setStatus(t, data.message || '<?= $escaper->escapeJs(__('Thinking…')) ?>');
            } else if (event === 'tool_start') {
                setStatus(t, friendlyTool(data.name || '') + '…');
            } else if (event === 'tool_done') {
                const summary = (data.summary || '').slice(0, 140);
                const cls = data.status === 'error' ? 'claudeai-tool-call--err' : '';
                t.insertAdjacentHTML('beforebegin',
                    '<div class="claudeai-tool-call ' + cls + '">' +
                    '<details class="claudeai-tool-details">' +
                    '<summary><span class="claudeai-tool-result-icon">' +
                    (data.status === 'error' ? '⚠️' : '✓') + '</span> ' +
                    '<span class="claudeai-tool-result-summary">' +
                    esc(friendlyTool(data.name || '')) + ' — ' + esc(summary) +
                    '</span></summary>' +
                    '</details></div>');
                setStatus(t, '<?= $escaper->escapeJs(__('Got it — figuring out what to do next…')) ?>');
                autoScroll();
            } else if (event === 'writing_reply') {
                setStatus(t, '<?= $escaper->escapeJs(__('Writing the reply…')) ?>');
            } else if (event === 'done') {
                done = data;
            } else if (event === 'error') {
                t.remove();
                bubble('err', '<strong><?= $escaper->escapeJs(__('Something went wrong:')) ?></strong> ' + esc(data.message || 'Unknown'));
            }
        };

        while (true) {
            const { value, done: streamDone } = await reader.read();
            if (streamDone) break;
            buffer += decoder.decode(value, { stream: true });
            let idx;
            while ((idx = buffer.indexOf('\n\n')) !== -1) {
                const chunk = buffer.slice(0, idx);
                buffer = buffer.slice(idx + 2);
                let evt = 'message', payload = '';
                for (const line of chunk.split('\n')) {
                    if (line.startsWith('event:')) evt = line.slice(6).trim();
                    else if (line.startsWith('data:')) payload += line.slice(5).trim();
                }
                if (payload) {
                    try { handle(evt, JSON.parse(payload)); } catch (e) { /* ignore */ }
                }
            }
        }

        if (!done) { t.remove(); return; }
        t.remove();

        conversationId = done.conversation_id || conversationId;
        conversation   = done.conversation || conversation;

        const aiBubble = bubble('ai', md(done.text || '(no reply)'));
        const u = done.usage || {};
        const cost = done.cost_display || '';
        const meta = (cost ? cost + ' · ' : '') +
            (u.input || 0) + ' in · ' + (u.output || 0) + ' out';
        const lastBody = aiBubble.querySelector('.claudeai-bubble-body');
        if (lastBody) lastBody.insertAdjacentHTML('beforeend', '<div class="claudeai-meta">' + meta + '</div>');
    }
    // Reset the send/stop button states whether the stream completed
    // normally, errored, or was aborted.
    function resetSendUi() {
        activeAbort = null;
        sendBtn.style.display = '';
        if (stopBtn) stopBtn.classList.remove('is-active');
    }

    async function send(message) {
        const attHtml = pendingAttachments.map(a => {
            if (a.preview_url) return '<img class="claudeai-bubble-attached" src="' + esc(a.preview_url) + '" alt="attachment">';
            return '<div class="claudeai-bubble-att-chip">📎 ' + esc(a.name) + '</div>';
        }).join('');
        bubble('user', esc(message) + attHtml);
        // After the user sends, always pin to bottom — overrides any
        // earlier upward scroll so the new exchange is in view.
        _stickToBottom = true;
        autoScroll(true);
        const sentAttachments = pendingAttachments.slice();
        pendingAttachments = [];
        renderAttachments();
        input.value = ''; input.style.height = 'auto';
        sendBtn.disabled = true;
        try {
            await streamSend(message, sentAttachments);
        } catch (e) {
            if (e.name === 'AbortError') {
                bubble('ai', '<em style="color:#b30000"><?= $escaper->escapeJs(__('Stopped — no more tokens spent.')) ?></em>');
            } else {
                bubble('err', '<strong><?= $escaper->escapeJs(__('Network problem:')) ?></strong> ' + esc(e.message));
            }
        } finally {
            sendBtn.disabled = false;
            resetSendUi();
            input.focus();
        }
    }

    input?.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 200) + 'px';
    });
    function shouldSend() {
        return input.value.trim() !== '' || pendingAttachments.length > 0;
    }
    input?.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            if (shouldSend()) send(input.value.trim());
        }
    });
    form?.addEventListener('submit', e => {
        e.preventDefault();
        if (shouldSend()) send(input.value.trim());
    });
    fileIn?.addEventListener('change', e => {
        const f = e.target.files && e.target.files[0];
        if (f) uploadFile(f);
        e.target.value = '';
    });
    document.querySelectorAll('.claudeai-chat-chip').forEach(chip => {
        chip.addEventListener('click', () => {
            input.value = chip.dataset.suggestion || '';
            input.focus();
            input.dispatchEvent(new Event('input'));
        });
    });

    // Reset to a brand-new conversation (clears feed + history + cid).
    function newChat() {
        conversation = [];
        conversationId = '';
        pendingAttachments = [];
        renderAttachments();
        feed.innerHTML = '<div class="claudeai-chat-empty">' +
            '<div class="claudeai-empty-mark">' + AI_GLYPH + '</div>' +
            '<h3><?= $escaper->escapeJs(__('How can I help today?')) ?></h3>' +
            '<p><?= $escaper->escapeJs(__('Just type what you want in plain English. I will do the rest.')) ?></p>' +
            '</div>';
        document.querySelectorAll('.claudeai-history-item').forEach(li => li.classList.remove('is-active'));
        input.focus();
    }
    document.getElementById('claudeai-new-chat')?.addEventListener('click', newChat);

    // Render a single tool_use block as a friendly chip + collapsed details.
    function renderToolUseChip(name, input) {
        const inputJson = JSON.stringify(input || {}, null, 2);
        const details = '<details class="claudeai-tool-details"><summary>' +
            '<span class="claudeai-tool-result-icon">✦</span> ' +
            '<span class="claudeai-tool-result-summary">' + esc(friendlyTool(name)) + '…</span>' +
            '</summary><pre>' + esc(inputJson) + '</pre></details>';
        feed.insertAdjacentHTML('beforeend', '<div class="claudeai-tool-call">' + details + '</div>');
        autoScroll();
    }
    // Render a tool_result block — pull the human summary if present, hide
    // the raw JSON behind a click-to-expand.
    function renderToolResultChip(content) {
        let parsed = null;
        let raw = '';
        if (typeof content === 'string') {
            raw = content;
            try { parsed = JSON.parse(content); } catch (e) { parsed = null; }
        } else if (Array.isArray(content)) {
            raw = content.map(x => (x && x.text) || '').join(' ');
            try { parsed = JSON.parse(raw); } catch (e) { parsed = null; }
        } else if (content && typeof content === 'object') {
            parsed = content; raw = JSON.stringify(content);
        }
        const status = (parsed && parsed.status) || 'success';
        const summary = parsed
            ? (parsed.summary || parsed.message || ('returned ' + (parsed.affected_count != null ? parsed.affected_count + ' items' : 'data')))
            : mb(raw, 100);
        const cls = status === 'error' ? ' claudeai-tool-call--err' : '';
        const pretty = parsed ? JSON.stringify(parsed, null, 2) : raw;
        const html = '<div class="claudeai-tool-call' + cls + '">' +
            '<details class="claudeai-tool-details">' +
            '<summary><span class="claudeai-tool-result-icon">' + (status === 'error' ? '⚠️' : '✓') + '</span> ' +
            '<span class="claudeai-tool-result-summary">' + esc(summary) + '</span></summary>' +
            '<pre>' + esc(pretty) + '</pre></details></div>';
        feed.insertAdjacentHTML('beforeend', html);
        autoScroll();
    }
    function mb(s, n) { s = String(s || ''); return s.length > n ? s.slice(0, n) + '…' : s; }

    // Replay one stored conversation into the feed in lightweight bubble form.
    function replay(messages) {
        feed.innerHTML = '';
        for (const msg of messages || []) {
            const blocks = Array.isArray(msg.content) ? msg.content
                         : [{ type: 'text', text: String(msg.content || '') }];
            const role = msg.role === 'assistant' ? 'ai' : 'user';
            for (const b of blocks) {
                if (b.type === 'text') {
                    bubble(role, md(b.text || ''));
                } else if (b.type === 'image' && b.source?.data) {
                    const uri = 'data:' + (b.source.media_type || 'image/png') + ';base64,' + b.source.data;
                    bubble(role, '<img class="claudeai-bubble-attached" src="' + esc(uri) + '" alt="">');
                } else if (b.type === 'document') {
                    bubble(role, '<div class="claudeai-bubble-att-chip">📄 attached document</div>');
                } else if (b.type === 'tool_use') {
                    renderToolUseChip(b.name || 'tool', b.input || {});
                } else if (b.type === 'tool_result') {
                    renderToolResultChip(b.content);
                }
            }
        }
        autoScroll(true);
    }

    async function loadConversation(cid) {
        if (!cid) return;
        try {
            const url = LOAD_URL + (LOAD_URL.includes('?') ? '&' : '?') + 'cid=' + encodeURIComponent(cid);
            const resp = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            const data = await resp.json();
            if (!data.success) {
                bubble('err', '<strong><?= $escaper->escapeJs(__('Could not load that chat:')) ?></strong> ' + esc(data.error || 'unknown'));
                return;
            }
            conversation = data.messages || [];
            conversationId = data.conversation_id || cid;
            replay(conversation);
            document.querySelectorAll('.claudeai-history-item').forEach(li => {
                li.classList.toggle('is-active', li.dataset.cid === cid);
            });
        } catch (e) {
            bubble('err', '<strong><?= $escaper->escapeJs(__('Network problem:')) ?></strong> ' + esc(e.message));
        }
    }

    document.querySelectorAll('.claudeai-history-item').forEach(li => {
        li.addEventListener('click', () => loadConversation(li.dataset.cid || ''));
    });
})();
</script>
