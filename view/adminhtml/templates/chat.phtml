<div class="claudeai-page">
    <?php if (!$block->isConfigured()): ?>
        <div class="message message-warning">
            <span><strong><?= $escaper->escapeHtml(__('Heads up')) ?></strong> —
                <?= $escaper->escapeHtml(__('Claude AI is not configured.')) ?>
