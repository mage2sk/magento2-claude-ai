<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <panth_claudeai>
            <general>
                <enabled>1</enabled>
                <model>claude-opus-4-7</model>
                <effort>high</effort>
                <max_tokens>8192</max_tokens>
                <max_iterations>8</max_iterations>
                <api_timeout>120</api_timeout>
            </general>
            <safety>
                <dry_run>1</dry_run>
                <max_bulk_update>500</max_bulk_update>
                <rate_limit_per_hour>60</rate_limit_per_hour>
                <require_confirmation>1</require_confirmation>
                <confirmation_threshold>5</confirmation_threshold>
            </safety>
            <tools>
                <get_products>1</get_products>
                <manage_products>1</manage_products>
                <update_product_price>1</update_product_price>
                <update_product_status>1</update_product_status>
                <update_inventory>1</update_inventory>
                <manage_categories>1</manage_categories>
                <customers>1</customers>
                <orders>1</orders>
                <manage_cms_pages>1</manage_cms_pages>
                <manage_cms_blocks>1</manage_cms_blocks>
                <store_insights>1</store_insights>
                <get_low_stock_products>1</get_low_stock_products>
                <store_info>1</store_info>
                <update_config>1</update_config>
                <set_store_logo>1</set_store_logo>
                <get_modules>1</get_modules>
                <database_query>1</database_query>
                <cache_reindex>1</cache_reindex>
                <restore_checkpoint>1</restore_checkpoint>
            </tools>
            <logging>
                <enabled>1</enabled>
                <retention_days>90</retention_days>
                <checkpoint_retention_days>30</checkpoint_retention_days>
                <file_logger>1</file_logger>
            </logging>
        </panth_claudeai>
    </default>
</config>
